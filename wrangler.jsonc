{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scms",
  "compatibility_date": "2026-03-10",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "seastar-cms-db",
      "database_id": "placeholder-id"
    }
  ]
}